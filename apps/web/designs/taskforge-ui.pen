              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "For terms questions, use the TaskForge GitHub repository contact channel.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            }
          ]
        }
      ]
