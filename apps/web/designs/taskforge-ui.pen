              "content": "Privacy Policy",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h1",
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "eeeBs",
              "name": "privDate",
              "fill": "$color-text-secondary",
              "content": "Last updated: March 30, 2026",
              "fontFamily": "Inter",
              "fontSize": "$font-size-small",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "FDhh4",
              "name": "p1",
              "fill": "$color-foreground",
              "content": "2. Information We Collect",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "mgkEg",
              "name": "p1b",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Account data, workspace content, billing metadata, and usage telemetry needed to operate TaskForge.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "WFQW9",
              "name": "p2",
              "fill": "$color-foreground",
              "content": "3. How We Use Information",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "B617h",
              "name": "p2b",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "To authenticate users, deliver features, communicate updates, support customers, and secure the platform.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "IpoNd",
              "name": "p3",
              "fill": "$color-foreground",
              "content": "4. Sharing",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "gj5vD",
              "name": "p3b",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "TaskForge does not sell personal data; data may be shared with service providers and as required by law.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "MwZpL",
              "name": "p4",
              "fill": "$color-foreground",
              "content": "5. Retention & Security",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "js6Jj",
              "name": "p4b",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Data is retained as needed for operations and legal compliance, with technical and organizational safeguards.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "yyTN7",
              "name": "p5",
              "fill": "$color-foreground",
              "content": "6. Your Rights",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
