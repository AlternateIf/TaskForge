              "fontSize": "$font-size-small",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "URJVT",
              "name": "termsSec1Title",
              "fill": "$color-foreground",
              "content": "1. Agreement to These Terms",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "KVAEt",
              "name": "termsSec1Body",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "By using TaskForge, you agree to these Terms and the Privacy Policy.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "72IkV",
              "name": "termsSec2Title",
              "fill": "$color-foreground",
              "content": "2. Permitted Use",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "kHNP6",
              "name": "termsSec2Body",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Use the service for lawful collaboration and productivity workflows.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "sfgdi",
              "name": "t3",
              "fill": "$color-foreground",
              "content": "3. Prohibited Conduct",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "rXxzL",
              "name": "t3b",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Do not misuse the service, attempt unauthorized access, or run harmful automation.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "9pgHw",
              "name": "t4",
              "fill": "$color-foreground",
              "content": "4. Customer Content",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "TcTKk",
              "name": "t4b",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "You retain ownership of submitted content while granting TaskForge a limited license to operate the service.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "uXDvH",
              "name": "t5",
              "fill": "$color-foreground",
              "content": "5. Limitation of Liability",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "zbsZl",
              "name": "t5b",
              "fill": "$color-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The service is provided as-is; liability is limited to the maximum extent permitted by law.",
              "fontFamily": "Inter",
              "fontSize": "$font-size-body",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "20OqR",
              "name": "t6",
              "fill": "$color-foreground",
              "content": "6. Contact",
              "fontFamily": "Inter",
              "fontSize": "$font-size-h3",
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "Pd5fL",
