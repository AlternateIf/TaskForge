# ── Server ──────────────────────────────────────────────
# Port the API server listens on (default: 3000)
PORT=3000
# Host to bind to (default: 0.0.0.0)
HOST=0.0.0.0
# Environment: development | production | test
NODE_ENV=development

# ── Database ────────────────────────────────────────────
# MySQL/MariaDB connection string
DATABASE_URL=mysql://taskforge:taskforge@localhost:3306/taskforge
# Connection pool size (default: 10)
DB_POOL_SIZE=10
# Idle connection timeout in ms (default: 30000)
DB_IDLE_TIMEOUT=30000

# ── Redis ───────────────────────────────────────────────
# Redis connection string (used for caching and real-time pub/sub)
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ────────────────────────────────────────────
# AMQP connection string for message queue
RABBITMQ_URL=amqp://taskforge:taskforge@localhost:5672

# ── Queue Prefetch (optional) ──────────────────────────
# Per-queue consumer prefetch counts. Higher = higher throughput priority.
# Defaults are tuned for real-time responsiveness over background throughput.
# QUEUE_PREFETCH_REALTIME=10
# QUEUE_PREFETCH_NOTIFICATION=5
# QUEUE_PREFETCH_EMAIL=3
# QUEUE_PREFETCH_SEARCH=1

# ── Meilisearch ─────────────────────────────────────────
# Meilisearch server URL
MEILISEARCH_URL=http://localhost:7700
# Meilisearch master key for authentication
MEILISEARCH_MASTER_KEY=taskforge_dev_key

# ── Auth ────────────────────────────────────────────────
# ⚠️ CHANGE THESE IN PRODUCTION — use strong random values
# Secret for signing JWT access tokens
JWT_SECRET=dev_jwt_secret_change_in_production
# Secret for signing JWT refresh tokens
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
# Secret for signing cookies
COOKIE_SECRET=dev-cookie-secret-change-in-production
# 32-character key for encrypting MFA secrets at rest
MFA_ENCRYPTION_KEY=dev-mfa-key-change-in-production-32ch

# ── OAuth (optional) ────────────────────────────────────
# Google OAuth 2.0 credentials (leave empty to disable)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# GitHub OAuth credentials (leave empty to disable)
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ── Email / SMTP ────────────────────────────────────────
# SMTP server hostname
SMTP_HOST=localhost
# SMTP server port (common: 25, 465, 587, 1025 for Mailpit)
SMTP_PORT=1025
# SMTP authentication (leave empty for unauthenticated local relay)
SMTP_USER=
SMTP_PASS=
# Use TLS for SMTP connection (set to "true" for production providers like SES, SendGrid)
SMTP_SECURE=false
# Reject self-signed TLS certificates (set to "false" for staging with self-signed certs)
SMTP_TLS_REJECT_UNAUTHORIZED=true
# Sender address for outgoing emails
EMAIL_FROM="TaskForge <noreply@taskforge.dev>"

# ── URLs ────────────────────────────────────────────────
# Public URL of the frontend app (used for OAuth redirects and email links)
FRONTEND_URL=http://localhost:5173
# Base URL shown in emails (e.g., deadline reminders)
APP_URL=http://localhost:5173
# Allowed CORS origin (typically the frontend URL)
CORS_ORIGIN=http://localhost:5173

# ── File Uploads ────────────────────────────────────────
# Directory for storing uploaded files (relative or absolute path)
UPLOAD_DIR=./uploads
# Maximum upload file size in bytes (default: 50 MB)
MAX_UPLOAD_SIZE_BYTES=52428800

# ── Logging ─────────────────────────────────────────────
# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
