# ── Database ────────────────────────────────────────────
DATABASE_URL=mysql://taskforge:taskforge@localhost:3306/taskforge

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ────────────────────────────────────────────
RABBITMQ_URL=amqp://taskforge:taskforge@localhost:5672

# ── Meilisearch ─────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=taskforge_dev_key

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production

# ── Email (Mailpit) ────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@taskforge.local

# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
