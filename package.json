{
  "name": "taskforge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test -- --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "turbo clean",
    "test-seed": "NODE_ENV=development bash ./scripts/test-seed.sh"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=8.0.5",
      "esbuild": ">=0.25.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
