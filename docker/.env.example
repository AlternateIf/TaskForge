# Docker Compose environment
#
# This file is loaded by docker-compose as env_file for the api and worker
# containers. For the full list of app-level variables, see:
#   apps/api/.env.example

# ── MariaDB (Docker service config) ────────────────────
# Root password for the MariaDB container
DB_ROOT_PASSWORD=taskforge
# Database name created on first start
DB_NAME=taskforge
# Application database user
DB_USER=taskforge
# Application database password
DB_PASSWORD=taskforge

# ── Connection strings (use Docker service hostnames) ──
# MySQL/MariaDB connection string (host = docker service name)
DATABASE_URL=mysql://taskforge:taskforge@mariadb:3306/taskforge
# Redis connection string
REDIS_URL=redis://redis:6379
# AMQP connection string for RabbitMQ
RABBITMQ_URL=amqp://taskforge:taskforge@rabbitmq:5672
# Meilisearch server URL
MEILISEARCH_URL=http://meilisearch:7700
# Meilisearch master key for authentication
MEILISEARCH_MASTER_KEY=taskforge_dev_key

# ── RabbitMQ (Docker service config) ───────────────────
# Default user created on first start
RABBITMQ_USER=taskforge
# Default password for the RabbitMQ user
RABBITMQ_PASSWORD=taskforge

# ── Auth secrets ── ⚠️ CHANGE IN PRODUCTION ────────────
# Secret for signing JWT access tokens
JWT_SECRET=dev_jwt_secret_change_in_production
# Secret for signing JWT refresh tokens
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
# Secret for signing cookies
COOKIE_SECRET=dev-cookie-secret-change-in-production
# 32-character key for encrypting MFA secrets at rest
MFA_ENCRYPTION_KEY=dev-mfa-key-change-in-production-32ch

# ── Email (Mailpit in Docker) ──────────────────────────
# SMTP server hostname (Mailpit container in dev)
SMTP_HOST=mailpit
# SMTP server port (Mailpit listens on 1025)
SMTP_PORT=1025

# ── Grafana (Docker service config) ────────────────────
# Grafana admin username
GRAFANA_USER=admin
# Grafana admin password
GRAFANA_PASSWORD=admin
