# ── MariaDB ─────────────────────────────────────────────
DB_ROOT_PASSWORD=taskforge
DB_NAME=taskforge
DB_USER=taskforge
DB_PASSWORD=taskforge

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ ────────────────────────────────────────────
RABBITMQ_USER=taskforge
RABBITMQ_PASSWORD=taskforge
RABBITMQ_URL=amqp://taskforge:taskforge@rabbitmq:5672

# ── Meilisearch ─────────────────────────────────────────
MEILISEARCH_MASTER_KEY=taskforge_dev_key
MEILISEARCH_URL=http://meilisearch:7700

# ── API ─────────────────────────────────────────────────
DATABASE_URL=mysql://taskforge:taskforge@mariadb:3306/taskforge
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production

# ── Email (Mailpit) ────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@taskforge.local

# ── Grafana ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
