# Docker Compose infrastructure variables
#
# This file defines compose-level variables shared across services.
# Per-service runtime configuration is split by service in docker/env/*.env:
# - docker/env/common.env
# - docker/env/api.env
# - docker/env/worker.env
# - docker/env/web.env
# - docker/env/mariadb.env
# - docker/env/rabbitmq.env
# - docker/env/meilisearch.env
# - docker/env/grafana.env
#
# Requires Docker Engine 20.10+ for json-file driver compress support.

# ── Docker log rotation ───────────────────────────────────────
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
DOCKER_LOG_COMPRESS=true

# ── Loki retention ────────────────────────────────────────────
LOKI_REJECT_OLD_SAMPLES_MAX_AGE=168h
LOKI_RETENTION_PERIOD=7d
LOKI_COMPACTION_INTERVAL=10m
