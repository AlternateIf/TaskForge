# Shared application environment (api + worker)
DATABASE_URL=mysql://taskforge:taskforge@mariadb:3306/taskforge
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://taskforge:taskforge@rabbitmq:5672
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=taskforge_dev_key

# Auth/security (change for non-local environments)
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
COOKIE_SECRET=dev-cookie-secret-change-in-production
MFA_ENCRYPTION_KEY=dev-mfa-key-change-in-production-32ch

# Email
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
EMAIL_FROM="TaskForge <noreply@taskforge.dev>"

# Uploads/logging
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=52428800
LOG_LEVEL=info
